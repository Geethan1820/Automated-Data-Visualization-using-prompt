# GVS DataNova Environment Configuration

# --- SERVER ---
PORT=5000
HOST=0.0.0.0
DATA_DIR=./data
JWT_SECRET_KEY=yoursecretkeyhere
JWT_REFRESH_SECRET_KEY=yourrefreshsecretkeyhere

# --- DATABASE ---
# Docker (see docker-compose.yml): use localhost when the API runs on your machine.
# postgresql+asyncpg://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/datanova
# Offline dev without Docker (SQLite fallback if DATABASE_URL unset in code — prefer Postgres above):
# DATABASE_URL=sqlite+aiosqlite:///./server/database.db

# --- CACHE (Redis) ---
REDIS_URL=redis://redis:6379/0

# --- AI ENGINE ---
# Get your API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
# Alternative: OPENAI_API_KEY=your_openai_api_key_here

# --- FRONTEND ---
VITE_API_URL=http://localhost:8000
